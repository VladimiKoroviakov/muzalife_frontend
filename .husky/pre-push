#!/bin/sh
# .husky/pre-push
#
# Runs before every `git push`.
# Ensures living-documentation tests pass and TypeDoc can be generated
# before code is pushed to the remote.

echo "🔬 Running living-documentation tests..."
npm run test:docs

echo "📖 Verifying TypeDoc generation..."
npm run docs --silent

echo "✅ Pre-push checks passed."

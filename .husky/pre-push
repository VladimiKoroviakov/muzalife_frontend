#!/bin/sh
# .husky/pre-push
#
# Runs before every `git push`.
# Ensures all tests (living-documentation + unit hook tests) pass and
# TypeDoc can be generated before code is pushed to the remote.

echo "🔬 Running full test suite (docs + unit)..."
npm test

echo "📖 Verifying TypeDoc generation..."
npm run docs --silent

echo "✅ Pre-push checks passed."
